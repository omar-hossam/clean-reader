{
  "manifest_version": 3,
  "name": "Clean Reader",
  "description": "Clean any webpage so you can focus on the content",
  "version": "v1.0",
  
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "Clean Reader"
  },
  
  "browser_specific_settings": {
    "gecko": {
      "id": "omarhossam50@proton.me"
    }
  },
  
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },
  
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "match_about_blank": false,
      "all_frames": true,
      "js": ["content/index.js"],
    },
  ],
}
